{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "vite-plugin-lit-ssg": ["../vite-plugin-lit-ssg/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts", "vite.config.*.ts"],
  "exclude": ["node_modules", "dist", "temp"]
}
