{
  "name": "vite-lit-ssg-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "pnpm monorepo for vite-plugin-lit-ssg",
  "scripts": {
    "build": "pnpm --filter vite-plugin-lit-ssg build",
    "dev": "pnpm --filter vite-plugin-lit-ssg dev",
    "typecheck": "pnpm --filter vite-plugin-lit-ssg typecheck",
    "test": "pnpm --filter vite-plugin-lit-ssg-tests test",
    "test:watch": "pnpm --filter vite-plugin-lit-ssg-tests test:watch",
    "playground:build": "pnpm --filter playground build",
    "playground:preview": "pnpm --filter playground preview"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
