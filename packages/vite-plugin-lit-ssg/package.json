{
  "name": "@cherrywind/vite-plugin-lit-ssg",
  "version": "0.0.1-alpha.3",
  "description": "Vite plugin for Lit static site generation",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.cjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "default": "./dist/browser.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "vite-lit-ssg": "dist/cli.cjs"
  },
  "files": [
    "dist",
    "*.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rspack build --config rspack.config.mjs --env kind=node-library --env clean=true && rspack build --config rspack.config.mjs --env kind=cli && rspack build --config rspack.config.mjs --env kind=browser && tsc -p tsconfig.build.json",
    "dev": "rspack build --config rspack.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "prepack": "node ./scripts/sync-publish-files.mjs copy",
    "postpack": "node ./scripts/sync-publish-files.mjs cleanup"
  },
  "dependencies": {
    "@lit-labs/ssr": "^4.0.0",
    "@lit-labs/ssr-client": "^1.1.7",
    "@literals/html-css-minifier": "^4.0.1",
    "@webcomponents/template-shadowroot": "^0.2.1",
    "magic-string": "^0.30.17",
    "tinyglobby": "^0.2.16",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@rspack/cli": "^1.7.11",
    "@rspack/core": "^1.7.11",
    "@types/node": "^22.0.0",
    "lit": "^3.3.2",
    "vite": "^6.0.0"
  },
  "peerDependencies": {
    "lit": "^3.0.0",
    "vite": "^5.0.0 || ^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "vite",
    "lit",
    "ssg",
    "static-site-generation",
    "web-components"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/susanforme/vite-lit-ssg.git",
    "directory": "packages/vite-plugin-lit-ssg"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}