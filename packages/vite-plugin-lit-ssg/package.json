{
  "name": "vite-plugin-lit-ssg",
  "version": "0.1.0",
  "description": "Vite plugin for Lit static site generation",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": "./dist/browser.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "vite-lit-ssg": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@lit-labs/ssr": "^4.0.0",
    "@lit-labs/ssr-client": "^1.1.7",
    "@webcomponents/template-shadowroot": "^0.2.1",
    "magic-string": "^0.30.17",
    "typescript": "^5.7.0",
    "tinyglobby": "^0.2.16"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "lit": "^3.3.2",
    "vite": "^6.0.0"
  },
  "peerDependencies": {
    "lit": "^3.0.0",
    "vite": "^5.0.0 || ^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "vite",
    "lit",
    "ssg",
    "static-site-generation",
    "web-components"
  ],
  "license": "MIT"
}
